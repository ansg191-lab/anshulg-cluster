# Hermes sudo permissions (scoped for security)

# Service control - hermes gateway and webui service only
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl start hermes-gateway
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop hermes-gateway
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart hermes-gateway
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl status hermes-gateway
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable hermes-gateway
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl disable hermes-gateway

hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl start hermes-webui
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop hermes-webui
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart hermes-webui
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl status hermes-webui
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable hermes-webui
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl disable hermes-webui

# daemon-reload affects all units (required after service file changes)
hermes ALL=(ALL) NOPASSWD: /usr/bin/systemctl daemon-reload

# Journal access - hermes logs only
hermes ALL=(ALL) NOPASSWD: /usr/bin/journalctl -u hermes-gateway *

# May add wireguard permissions in the future...
